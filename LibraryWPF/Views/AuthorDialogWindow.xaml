<Window x:Class="LibraryWPF.Views.AuthorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автор" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#9C27B0" Padding="15" CornerRadius="5" Margin="0,0,0,30">
            <TextBlock x:Name="TitleText" Text="ДОБАВЛЕНИЕ АВТОРА" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Поля формы -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Имя" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNameBox" Height="35" FontSize="14" Padding="10,0" Margin="0,0,0,15"/>

            <TextBlock Text="Фамилия" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="LastNameBox" Height="35" FontSize="14" Padding="10,0" Margin="0,0,0,15"/>

            <TextBlock Text="Дата рождения" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="BirthDatePicker" Height="35" FontSize="14" Margin="0,0,0,15"/>

            <TextBlock Text="Страна" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="CountryBox" Height="35" FontSize="14" Padding="10,0" Margin="0,0,0,15"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="✓ Сохранить" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Click="SaveButton_Click" Margin="0,0,10,0"/>
            <Button Content="✖ Отмена" Width="100" Height="35" 
                    Background="#F44336" Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>