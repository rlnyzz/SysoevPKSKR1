<Window x:Class="LibraryWPF.Views.AuthorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление авторами" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#9C27B0" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <TextBlock Text="УПРАВЛЕНИЕ АВТОРАМИ" 
                       FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- DataGrid с авторами -->
        <DataGrid Grid.Row="1" x:Name="AuthorsGrid" Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id_author}" Width="50"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Firstname}" Width="150"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Lastname}" Width="150"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding Birthdate, StringFormat={}{0:dd.MM.yyyy}}" Width="150"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="➕ Добавить" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Click="AddAuthor_Click" Margin="5"/>
            <Button Content="✏ Редактировать" Width="100" Height="35" 
                    Background="#2196F3" Foreground="White"
                    Click="EditAuthor_Click" Margin="5"/>
            <Button Content="🗑 Удалить" Width="100" Height="35" 
                    Background="#F44336" Foreground="White"
                    Click="DeleteAuthor_Click" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>