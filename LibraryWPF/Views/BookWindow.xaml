<Window x:Class="LibraryWPF.Views.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование книги" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="5" Margin="0,0,0,30">
            <TextBlock x:Name="TitleText" Text="ДОБАВЛЕНИЕ КНИГИ" 
                       FontSize="20" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Поля формы -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Название -->
                <TextBlock Text="Название книги*" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="TitleBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <!-- Автор -->
                <TextBlock Text="Автор" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="AuthorComboBox" Height="40" FontSize="14" Margin="0,0,0,20"
                          DisplayMemberPath="FullNameReverse"/>
                <TextBlock Text="или укажите вручную:" FontSize="12" Foreground="Gray" Margin="0,-15,0,5"/>
                <TextBox x:Name="AuthorManualBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <!-- Жанр -->
                <TextBlock Text="Жанр" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="GenreComboBox" Height="40" FontSize="14" Margin="0,0,0,20"
                          DisplayMemberPath="Name"/>
                <TextBlock Text="или укажите вручную:" FontSize="12" Foreground="Gray" Margin="0,-15,0,5"/>
                <TextBox x:Name="GenreManualBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <!-- Год издания -->
                <TextBlock Text="Год издания" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="YearBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <!-- ISBN -->
                <TextBlock Text="ISBN" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="IsbnBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <!-- Количество -->
                <TextBlock Text="Количество в наличии" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="QuantityBox" Height="40" FontSize="14" Padding="10,0" Margin="0,0,0,20"/>

                <TextBlock Text="* обязательное поле" FontSize="12" Foreground="Red" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="✓ Сохранить" Width="120" Height="40" 
                    Background="#4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Click="SaveButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="✖ Отмена" Width="120" Height="40" 
                    Background="#F44336" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>