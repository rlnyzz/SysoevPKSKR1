<Window x:Class="LibraryWPF.Views.GenreDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Жанр" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#FF9800" Padding="15" CornerRadius="5" Margin="0,0,0,30">
            <TextBlock x:Name="TitleText" Text="ДОБАВЛЕНИЕ ЖАНРА" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Поля формы -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Название жанра" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" Height="35" FontSize="14" Padding="10,0" Margin="0,0,0,15"/>

            <TextBlock Text="Описание" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionBox" Height="80" FontSize="14" Padding="10,0" 
                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="✓ Сохранить" Width="100" Height="35" 
                    Background="#4CAF50" Foreground="White"
                    Click="SaveButton_Click" Margin="0,0,10,0"/>
            <Button Content="✖ Отмена" Width="100" Height="35" 
                    Background="#F44336" Foreground="White"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>