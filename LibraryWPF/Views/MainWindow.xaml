<Window x:Class="LibraryWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryWPF.ViewModels"
        mc:Ignorable="d"
        Title="Библиотека - Управление книгами" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#2196F3" Padding="15" CornerRadius="5" Margin="0,0,0,20">
            <TextBlock Text="УПРАВЛЕНИЕ БИБЛИОТЕЧНЫМ ФОНДОМ" 
                       FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" Background="#F5F5F5" Padding="20" CornerRadius="5" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="🔍 Поиск:" FontSize="16" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Width="300" Height="35" FontSize="14"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0"/>
                </StackPanel>


                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="👤 Автор:" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="200" Height="35" FontSize="14"
                              ItemsSource="{Binding Authors}"
                              SelectedItem="{Binding SelectedAuthorFilter}"
                              DisplayMemberPath="FullNameReverse">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullNameReverse}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="🎭 Жанр:" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="200" Height="35" FontSize="14"
                              ItemsSource="{Binding Genres}"
                              SelectedItem="{Binding SelectedGenreFilter}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <Button Grid.Column="3" Content="✖ Сбросить" 
                        Width="120" Height="35" FontSize="14"
                        Background="#FF5722" Foreground="White"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="250"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="200"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding GenreName}" Width="150"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="80"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="100"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding Isbn}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#E3F2FD" Padding="20" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,30,0">
                    <TextBlock Text="📊 Статистика:" FontSize="14" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalBooks}" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="книг," FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding TotalInStock}" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="экз. в наличии" FontSize="14" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Content="➕ Добавить книгу" 
                        Style="{StaticResource ActionButton}"
                        Background="#4CAF50" Foreground="White"
                        Command="{Binding AddBookCommand}"/>

                <Button Grid.Column="3" Content="✏ Редактировать" 
                        Style="{StaticResource ActionButton}"
                        Background="#2196F3" Foreground="White"
                        Command="{Binding EditBookCommand}"/>

                <Button Grid.Column="4" Content="🗑 Удалить" 
                        Style="{StaticResource ActionButton}"
                        Background="#F44336" Foreground="White"
                        Command="{Binding DeleteBookCommand}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" 
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,20,0,0">
            <Button Content="👥 Управление авторами" 
                    Style="{StaticResource ActionButton}"
                    Background="#9C27B0" Foreground="White"
                    Command="{Binding ManageAuthorsCommand}"
                    Margin="5"/>
            <Button Content="🎭 Управление жанрами" 
                    Style="{StaticResource ActionButton}"
                    Background="#FF9800" Foreground="White"
                    Command="{Binding ManageGenresCommand}"
                    Margin="5"/>
        </StackPanel>
    </Grid>
</Window>